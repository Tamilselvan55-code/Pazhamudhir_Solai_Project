datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName                   String
  phoneNumber                String   @unique
  email                      String   @unique
  password                   String
  isAdmin                    Boolean  @default(false)
  role                       String   @default("User")
  isBlocked                  Boolean  @default(false)
  blockedAt                  DateTime?
  blockedReason              String?
  isVerified                 Boolean  @default(false)
  verifiedAt                 DateTime?
  emailOtp                   String?
  emailOtpExpires            DateTime?
  verificationAttempts       Int      @default(0)
  isEmailVerified            Boolean  @default(false)
  emailVerificationOTP       String?
  emailVerificationOTPExpiry DateTime?
  emailVerificationAttempts  Int      @default(0)
  otp                        String?
  otpExpires                 DateTime?
  emailVerified              Boolean  @default(false)
  verificationOTP            String?
  verificationOTPExpires     DateTime?
  suspendedUntil             DateTime?
  loginAttempts              Int      @default(0)
  lockUntil                  DateTime?

  deliveryAddress            Json?
  addresses                  UserAddress[]
  wishlist                   WishlistItem[]
  orders                     Order[]
  notifications              Notification[]
  notificationSettings       NotificationSettings?

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model UserAddress {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String  @db.Uuid
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String  @default("Home")
  fullAddress String?
  street      String?
  city        String?
  state       String?
  pincode     String?
  lat         Float?
  lon         Float?
  isDefault   Boolean @default(false)
}

model WishlistItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String  @db.Uuid
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Admin {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  email         String   @unique
  password      String
  role          String   @default("Admin")
  permissions   Json     @default("{\"products\":true,\"orders\":true,\"reports\":true,\"settings\":true,\"users\":true,\"notifications\":true}")
  loginAttempts Int      @default(0)
  lockUntil     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Category {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String    @unique
  tamilName    String?   @default("")
  description  String?   @default("")
  image        String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Product {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  nameTamil    String?        @default("")
  tamilName    String?        @default("")
  englishName  String?        @default("")
  sku          String?        @default("")
  price        Float
  categoryId   String?        @db.Uuid
  category     Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categorySlug String         @map("category") // slug string e.g. 'vegetables' to preserve current queries
  image        String?        @default("")
  images       String[]       @default([])
  inStock      Boolean        @default(true)
  stock        Int            @default(20)
  isActive     Boolean        @default(true)
  isFeatured   Boolean        @default(false)
  discount     Float          @default(0)
  offerTag     String?        @default("")
  description  String?        @default("")
  unit         String?        @default("1 kg")
  isTrending   Boolean        @default(false)
  isBestSeller Boolean        @default(false)
  orderItems   OrderItem[]
  wishlistBy   WishlistItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([name, categorySlug])
}

model Order {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String         @db.Uuid
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceNumber   String?        @unique
  shippingAddress Json
  recipient       Json?
  totalPrice      Float          @default(0.0)
  deliveryFee     Float          @default(0.0)
  gstAmount       Float          @default(0.0)
  couponCode      String?        @default("")
  couponDiscount  Float          @default(0)
  paymentMethod   String         @default("COD")
  paymentStatus   String         @default("Pending")
  transactionId   String?        @default("")
  paymentAuditLog Json[]
  status          String         @default("Pending")
  statusHistory   Json[]
  isDelivered     Boolean        @default(false)
  deliveredAt     DateTime?
  notes           String?        @default("")
  orderItems      OrderItem[]
  notifications   Notification[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model OrderItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String  @db.Uuid
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int
  image     String?
  price     Float
}

model Notification {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?  @db.Uuid
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  message       String
  type          String
  isRead        Boolean  @default(false)
  link          String?  @default("")
  role          String   @default("customer")
  icon          String?  @default("bell")
  priority      String?  @default("normal")
  actionUrl     String?  @default("")
  customerName  String?  @default("")
  phone         String?  @default("")
  orderId       String?  @db.Uuid
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  invoiceNumber String?  @default("")
  orderTotal    Float?   @default(0)
  totalItems    Int?     @default(0)
  paymentMethod String?  @default("")
  orderStatus   String?  @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NotificationSettings {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                   String   @unique @db.Uuid
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderNotifications       Boolean  @default(true)
  offerNotifications       Boolean  @default(true)
  deliveryNotifications    Boolean  @default(true)
  securityNotifications    Boolean  @default(true)
  promotionalNotifications Boolean  @default(true)
  generalNotifications     Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model AdminNotification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreSettings {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeName                String   @default("Tiruchendur Murugan Pazhamudhir Solai")
  storeLogo                String?  @default("")
  storeAddress             String?  @default("Sriperumbudur, Tamil Nadu - 602105")
  phone                    String?  @default("+91 94443 62453")
  email                    String?  @default("thiruchendurmurugan192@gmail.com")
  supportWhatsApp          String?  @default("+91 94443 62453")
  workingHours             String?  @default("06:00 AM - 09:00 PM")
  deliveryRadiusKm         Float    @default(30)
  currency                 String?  @default("₹")
  gstPercentage            Float?   @default(0)
  invoicePrefix            String?  @default("INV-")
  invoiceFooter            String?  @default("Thank you for shopping with us! Visit again.")
  storeDescription         String?  @default("Fresh fruits, vegetables, groceries and daily essentials.")
  location                 Json     @default("{\"lat\":12.9666144,\"lon\":79.9458077}")
  websiteName              String?  @default("Tiruchendur Murugan Pazhamudhir Solai")
  websiteLogo              String?  @default("")
  browserTitle             String?  @default("Tiruchendur Murugan Pazhamudhir Solai - Online Grocery Store")
  favicon                  String?  @default("")
  primaryThemeColor        String?  @default("#16a34a")
  secondaryThemeColor      String?  @default("#81c784")
  homepageBanner           String?  @default("")
  announcementBanner       String?  @default("Welcome to Tiruchendur Murugan Pazhamudhir Solai! Fresh fruits and vegetables.")
  footerContent            String?  @default("© 2026 Tiruchendur Murugan Pazhamudhir Solai. All rights reserved.")
  defaultLanguage          String?  @default("en")
  defaultCurrency          String?  @default("₹")
  defaultTheme             String?  @default("light")
  enableProductReviews     Boolean  @default(true)
  enableWishlist           Boolean  @default(true)
  enableSearchSuggestions  Boolean  @default(true)
  enableNotifications      Boolean  @default(true)
  maintenanceMode          Boolean  @default(false)
  disableCustomerLogin     Boolean  @default(false)
  disableRegistration      Boolean  @default(false)
  disableCheckout          Boolean  @default(false)
  disableForgotPassword    Boolean  @default(false)
  disableOrderPlacement    Boolean  @default(false)
  minOrderValue            Float?   @default(0)
  maxOrderValue            Float?   @default(100000)
  freeDeliveryThreshold    Float?   @default(500)
  deliveryCharges          Float?   @default(40)
  deliveryTiming           String?  @default("Same Day Delivery")
  orderPrefix              String?  @default("ORD-")
  autoAcceptOrders         Boolean  @default(false)
  autoGenerateInvoice      Boolean  @default(true)
  orderStatusColors        Json     @default("{\"Pending\":\"#F59E0B\",\"Accepted\":\"#3B82F6\",\"Out for Delivery\":\"#06B6D4\",\"Delivered\":\"#10B981\",\"Cancelled\":\"#EF4444\"}")
  cancellationTimeLimit    Float?   @default(30)
  enableOrderNotifications Boolean  @default(true)
  enableRegistrationNotifications Boolean @default(true)
  enableLowStockAlerts     Boolean  @default(true)
  enableOfferNotifications Boolean  @default(true)
  enableEmailNotifications Boolean  @default(true)
  enableBrowserNotifications Boolean @default(true)
  sessionTimeout           Float?   @default(15)
  maxLoginAttempts         Int?     @default(5)
  passwordPolicy           String?  @default("Medium")
  admin2FA                 Boolean  @default(false)
  smtpHost                 String?  @default("")
  smtpPort                 Int?     @default(587)
  smtpUsername             String?  @default("")
  smtpPassword             String?  @default("")
  senderName               String?  @default("Tiruchendur Murugan Pazhamudhir Solai")
  senderEmail              String?  @default("")
  dashboardRefreshInterval Float?   @default(30)
  enableSalesCharts        Boolean  @default(true)
  enableRevenueReports     Boolean  @default(true)
  enableTopProducts        Boolean  @default(true)
  enableCustomerStats      Boolean  @default(true)
  offersBanner             String?  @default("")
  aboutUs                  String?  @default("We are a dedicated local grocery store providing fresh organic goods.")
  contactUs                String?  @default("Contact us via phone or email.")
  privacyPolicy            String?  @default("Your privacy is our priority.")
  termsAndConditions       String?  @default("Standard terms and conditions apply.")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Offer {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title              String
  discountPercentage Float
  minOrderValue      Float    @default(0)
  validFrom          DateTime
  validUntil         DateTime
  status             String   @default("Active")
  bannerImage        String?  @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminName  String   @default("System Admin")
  action     String
  targetType String
  targetId   String?
  targetName String?
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  eventType   String   @default("Business Reminder")
  date        String
  description String?  @default("")
  createdBy   String?  @default("Admin")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PasswordReset {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String
  otp        String
  expiresAt  DateTime
  verified   Boolean  @default(false)
  resetToken String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PendingUser {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName                   String
  phoneNumber                String
  email                      String
  password                   String
  emailVerificationOTP       String
  emailVerificationOTPExpiry DateTime
  emailVerificationAttempts  Int      @default(0)
  resendAttempts             Int      @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}
